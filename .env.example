# Margonem Bot — konfiguracja
# Skopiuj do .env i uzupełnij wartości

# ═══ AI (OpenRouter) ═══
MAW_AI_API_KEY=
MAW_AI_MODEL=meta-llama/llama-3-8b-instruct:free
MAW_BOT_NICK=Certyfikowany Janusz

# ═══ Serwer lokalny ═══
MAW_DEV_PORT=3847

# ═══ Redis (opcjonalny — fallback: pamięć RAM) ═══
MAW_REDIS_ENABLED=false
# REDIS_URL=redis://127.0.0.1:6379

# ═══ Dane Logowania i Postaci ═══
MARGONEM_LOGIN=twoj_login
MARGONEM_PASSWORD=twoje_haslo
MARGONEM_START_CHAR=NazwaPostaci
MARGONEM_TOTP= # Opcjonalne 2FA, pozostaw puste jeśli nie używasz

# ═══ Puppeteer ═══
MAW_HEADLESS=false
MAW_GAME_SERVER=tempest
# Pełny URL wchodzenia do gry (opcjonalny, domyślnie: https://www.margonem.pl/)
# MAW_GAME_URL=https://tempest.margonem.pl/
