<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory app:title="Połączenie i Sieć">
        <EditTextPreference
            app:key="server_url"
            app:title="@string/server_url"
            app:useSimpleSummaryProvider="true"
            app:defaultValue="http://zephyr.proxy.rlwy.net:14192/dashboard/" />

        <SwitchPreferenceCompat
            app:key="desktop_mode"
            app:title="@string/desktop_mode"
            app:summary="@string/desktop_mode_summary"
            app:defaultValue="false" />

        <SwitchPreferenceCompat
            app:key="force_dark"
            app:title="@string/force_dark"
            app:summary="@string/force_dark_summary"
            app:defaultValue="true" />

        <Preference
            app:key="clear_cache"
            app:title="@string/clear_cache"
            app:summary="@string/clear_cache_summary" />
    </PreferenceCategory>

    <PreferenceCategory app:title="Bezpieczeństwo i Prywatność">
        <SwitchPreferenceCompat
            app:key="use_biometrics"
            app:title="Blokada Biometryczna"
            app:summary="Wymagaj odcisku palca przy starcie bota"
            app:defaultValue="false" />

        <SwitchPreferenceCompat
            app:key="screenshot_protect"
            app:title="@string/screenshot_protect"
            app:summary="@string/screenshot_protect_summary"
            app:defaultValue="false" />

        <SwitchPreferenceCompat
            app:key="enable_stealth_mode"
            app:title="Tryb Kamuflażu"
            app:summary="Dotknij ekranu 2 palcami, aby ukryć bota"
            app:defaultValue="false" />

        <SwitchPreferenceCompat
            app:key="enable_ufo_protocol"
            app:title="@string/ufo_abduction"
            app:summary="@string/ufo_abduction_summary"
            app:defaultValue="false" />

        <SwitchPreferenceCompat
            app:key="enable_morse_flashlight"
            app:title="@string/morse_flashlight"
            app:summary="@string/morse_flashlight_summary"
            app:defaultValue="false" />

        <ListPreference
            app:key="stealth_mode_type"
            app:title="Typ Kamuflażu"
            app:entries="@array/stealth_type_entries"
            app:entryValues="@array/stealth_type_values"
            app:defaultValue="0" />

        <EditTextPreference
            app:key="stealth_url"
            app:title="Strona Kamuflażu"
            app:summary="URL strony wyświetlanej w trybie kamuflażu"
            app:defaultValue="https://www.wikipedia.org"
            app:dependency="enable_stealth_mode" />
    </PreferenceCategory>

    <PreferenceCategory app:title="Ekran i Interfejs">
        <SwitchPreferenceCompat
            app:key="keep_screen_on"
            app:title="@string/keep_screen_on"
            app:summary="@string/keep_screen_on_summary"
            app:defaultValue="true" />

        <SwitchPreferenceCompat
            app:key="immersive_mode"
            app:title="Tryb Pełnoekranowy"
            app:summary="Ukrywa pasek stanu i nawigacji"
            app:defaultValue="true" />

        <SwitchPreferenceCompat
            app:key="shake_refresh"
            app:title="@string/shake_refresh"
            app:summary="@string/shake_refresh_summary"
            app:defaultValue="false" />

        <SwitchPreferenceCompat
            app:key="volume_control"
            app:title="@string/volume_control"
            app:summary="@string/volume_control_summary"
            app:defaultValue="false" />

        <ListPreference
            app:key="orientation_lock"
            app:title="Blokada Orientacji"
            app:entries="@array/orientation_entries"
            app:entryValues="@array/orientation_values"
            app:defaultValue="0" />
    </PreferenceCategory>

    <PreferenceCategory app:title="Funkcje Bota">
        <SwitchPreferenceCompat
            app:key="enable_js_bridge"
            app:title="Interfejs Skryptów"
            app:summary="Pozwala botowi wysyłać powiadomienia do Androida"
            app:defaultValue="true" />

        <SwitchPreferenceCompat
            app:key="enable_pip"
            app:title="Tryb Okienkowy (PiP)"
            app:summary="Zminimalizuj bota do małego okna przy wyjściu"
            app:defaultValue="true" />

        <ListPreference
            app:key="panic_button_action"
            app:title="Przycisk Paniki (Volume Down)"
            app:summary="Akcja przy długim naciśnięciu Volume Down"
            app:entries="@array/panic_entries"
            app:entryValues="@array/panic_values"
            app:defaultValue="0" />

        <SwitchPreferenceCompat
            app:key="log_console"
            app:title="@string/log_console"
            app:summary="@string/log_console_summary"
            app:defaultValue="false" />

        <EditTextPreference
            app:key="auto_refresh_interval"
            app:title="Auto-Odświeżanie (min)"
            app:summary="0 = wyłączone"
            app:defaultValue="0" />
    </PreferenceCategory>

    <PreferenceCategory app:title="Dźwięki i Efekty">
        <SwitchPreferenceCompat
            app:key="enable_sound"
            app:title="Dźwięki Systemowe (Beep)"
            app:summary="Sygnały dźwiękowe przy akcjach"
            app:defaultValue="true" />

        <SwitchPreferenceCompat
            app:key="enable_startup_music"
            app:title="Muzyka Startowa"
            app:summary="Graj Millennium przy uruchamianiu bota"
            app:defaultValue="true" />
    </PreferenceCategory>

</PreferenceScreen>
